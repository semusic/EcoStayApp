<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Room Image -->
        <ImageView
            android:id="@+id/imageViewRoom"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/room_placeholder"
            android:contentDescription="Room Image" />

        <!-- Room Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Room Name -->
            <TextView
                android:id="@+id/textViewRoomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Room Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Price -->
            <TextView
                android:id="@+id/textViewPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LKR 299.00/night"
                android:textSize="16sp"
                android:textColor="@color/primary_color"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- Max Guests -->
            <TextView
                android:id="@+id/textViewGuests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Max 4 guests"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/textViewStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/success_color"
                android:layout_marginTop="4dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Toggle Availability Button -->
                <Button
                    android:id="@+id/btnToggleAvailability"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Toggle Status"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/primary_color"
                    android:layout_marginEnd="8dp" />

                <!-- More Options Icon (3 dots) -->
                <ImageView
                    android:id="@+id/btnMoreOptions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_more_vert"
                    android:background="@drawable/rounded_icon_button"
                    android:backgroundTint="@color/divider_color"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="More options" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

