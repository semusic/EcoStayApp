<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Booking Details"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/textViewBookingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMED"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_status_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- Booking Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking Information"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/textViewBookingIdDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking ID: BK123456"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewBookingDateDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booked: Dec 10, 2024"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewPaymentStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment: Paid"
                android:textSize="14sp"
                android:textColor="@color/eco_green_dark"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Guest Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guest Information"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/textViewGuestName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guest: John Doe"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewGuestEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email: john@example.com"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Room/Activity Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation Details"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/textViewRoomNameDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mountain View Cabin"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewRoomType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Type: ROOM"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewGuestsDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guests: 2"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Dates and Pricing Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dates &amp; Pricing"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/textViewCheckInDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Check-in: Dec 15, 2024"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewCheckOutDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Check-out: Dec 17, 2024"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewTotalPriceDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: LKR 150.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
