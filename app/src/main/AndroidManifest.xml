<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Image permissions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EcoStayApp">
        
        <!-- Splash Activity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.EcoStayApp.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Onboarding Activity -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.EcoStayApp.NoActionBar" />
        
        <!-- Sign In Activity -->
        <activity
            android:name=".SignInActivity"
            android:exported="false"
            android:theme="@style/Theme.EcoStayApp.NoActionBar" />
        
        <!-- Register Activity -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.EcoStayApp.NoActionBar" />
        
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        
        <!-- Room Booking Activity -->
        <activity
            android:name=".RoomBookingActivity"
            android:exported="false" />
        
        <!-- Activity Booking Activity -->
        <activity
            android:name=".ActivityBookingActivity"
            android:exported="false" />
        
        <!-- Profile Activity -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".NotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.EcoStayApp.NoActionBar" />
        
        <activity
            android:name=".PersonalInfoActivity"
            android:exported="false" />
        
        <activity
            android:name=".SecuritySettingsActivity"
            android:exported="false" />
        
        <activity
            android:name=".ActivitiesCalendarActivity"
            android:exported="false" />
        
        <!-- Payment Activity -->
        <activity
            android:name=".PaymentActivity"
            android:exported="false" />
        
        <!-- Admin Activities -->
        <activity
            android:name=".AdminLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.EcoStayApp.NoActionBar" />
        
        <activity
            android:name=".AdminActivity"
            android:exported="false" />
        
        <activity
            android:name=".AddRoomActivity"
            android:exported="false" />
        
        <activity
            android:name=".AdminBookingsActivity"
            android:exported="false" />
        
        <activity
            android:name=".PaymentsActivity"
            android:exported="false" />
        
        <!-- Setup Activity (Development Only) -->
        <activity
            android:name=".SetupActivity"
            android:exported="false" />
        
        <!-- Admin Notifications Activity -->
        <activity
            android:name=".AdminNotificationsActivity"
            android:exported="false" />
        
        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        
    </application>

</manifest>